@startuml GraphTasksTDEs_Deployment
!theme plain
title Diagrama de Implantação - Sistema de Grafos

node "Developer Machine" as DevMachine {
    artifact "Source Code (src/)" as SourceCode
    artifact "Documentation (docs/)" as Docs
    artifact "Build Scripts" as BuildScripts
}

node "Java Runtime Environment" as JRE {
    artifact "Compiled Classes (output/)" as CompiledClasses
    artifact "JVM" as JVM
}

folder "Project Root" as ProjRoot {
    file ".gitignore" as GitIgnore
    file "START_HERE.md" as StartHere
    file "README.md" as Readme
}

folder "Binary Data (/data)" as DataDir {
    file "*.bin files" as BinFiles
}

SourceCode -.-> CompiledClasses: javac compile
CompiledClasses -.-> JVM: java execute
JVM -.-> DataDir: read/write .bin

SourceCode --> Docs: documents
BuildScripts -.-> CompiledClasses: automate compilation

note right of JVM
  Java 8+
  Packages:
  - br.edu.grafo.model
  - br.edu.grafo.algorithm
  - br.edu.grafo.util
  - br.edu.grafo.app
end note

note right of DataDir
  Location: /data
  Files saved by GraphStorage
  Format: Java Serialized Objects
end note


@enduml
